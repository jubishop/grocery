{
  "name": "west-seattle-grocery-index",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "vinext start",
    "lint": "tsc --noEmit",
    "test": "node --test tests/*.test.ts",
    "data:match": "node scripts/match-instacart-aliases.mjs && node scripts/match-whole-foods.mjs && node scripts/match-direct-store.mjs safeway && node scripts/match-direct-store.mjs qfc",
    "data:build": "npm run data:match && node scripts/build-database.mjs && node scripts/generate-csv.mjs",
    "data:refine": "node scripts/refine-dataset.mjs",
    "data:csv": "node scripts/generate-csv.mjs",
    "data:audit-pricing": "node scripts/audit-weight-pricing.mjs",
    "images": "node scripts/download-images.mjs"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "react-server-dom-webpack": "19.2.6",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
